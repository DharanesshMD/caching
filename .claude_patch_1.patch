diff --git a/app/templates/demo/server.html b/app/templates/demo/server.html
new file mode 100644
index 0000000..6a115af
--- /dev/null
+++ b/app/templates/demo/server.html
@@ -0,0 +1,14 @@
+{% extends "base.html" %}
+
+{% block content %}
+  <h2>Server cache demo</h2>
+
+  {% if cache_result.hit %}
+    <span class="badge badge-hit">✓ CACHE HIT — {{ cache_result.latency_ms|round(2) }}ms</span>
+  {% else %}
+    <span class="badge badge-miss">✗ CACHE MISS — fetched from origin ({{ cache_result.latency_ms|round(2) }}ms)</span>
+  {% endif %}
+
+  <h3>Payload</h3>
+  <pre>{{ cache_result.value }}</pre>
+{% endblock %}
